# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pandoroom?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS
CORS_ORIGINS=https://pandoroom.e-rma.ru,https://pandoroom-admin.e-rma.ru

# S3 Storage (optional - if not set, local storage will be used)
S3_ENABLED=false
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=pandoroom
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Server
PORT=3001
NODE_ENV=production

# Notifications
TELEGRAM_BOT_TOKEN=
SMS_PROVIDER=stub
SMS_API_KEY=
MAX_BOT_TOKEN=

# Google Calendar
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# TBank Payments
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
TBANK_API_URL=https://securepay.tinkoff.ru/v2
PAYMENT_SUCCESS_URL=https://pandoroom.e-rma.ru/payment/success
PAYMENT_FAIL_URL=https://pandoroom.e-rma.ru/payment/fail

# iiko Integration
IIKO_WEBHOOK_SECRET=
IIKO_API_URL=https://api-ru.iiko.services
IIKO_API_LOGIN=
IIKO_ORGANIZATION_ID=
